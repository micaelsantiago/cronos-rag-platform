{
  "permissions": {
    "allow": [
      "Bash(git commit -m *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git push origin main)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(gh log *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh repo view *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(.venv/bin/ruff check *)",
      "Bash(.venv/bin/ruff format *)",
      "Bash(.venv/bin/mypy *)",
      "Bash(alembic upgrade *)",
      "Bash(alembic downgrade *)",
      "Bash(alembic revision *)",
      "Bash(alembic history)",
      "Bash(alembic current)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs *)",
      "Bash(find . -name * -type f)",
      "Bash(find . -type f *)",
      "Bash(ls *)",
      "Bash(mkdir -p *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(docker compose down -v *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('file_path',''))\" 2>/dev/null); if [[ \"$FILE\" == *.py ]]; then .venv/bin/ruff check --fix \"$FILE\" 2>/dev/null; fi"
          }
        ]
      }
    ]
  }
}
