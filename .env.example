# === App ===
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-this-to-a-random-32-byte-hex-string
DEBUG=true

# === Database ===
DATABASE_URL=postgresql+asyncpg://cronos:cronos@postgres:5432/cronos_db

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Storage (MinIO) ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=cronos
MINIO_SECRET_KEY=cronos123
MINIO_BUCKET=cronos-documents
MINIO_USE_SSL=false

# === AI Providers ===
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
EMBEDDING_MODEL=text-embedding-3-small

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === JWT ===
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === CORS ===
CORS_ORIGINS=["http://localhost:3000"]
